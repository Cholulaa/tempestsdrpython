# TempestSDR edge-probe configuration (sourced by run-agent.sh / systemd).
# Copy to /etc/tempestsdr/agent.env and edit for this probe.

# --- control server ---
SERVER=http://your-control-server:9000
DEVICE_ID=pi-01
API_KEY=                       # must match the server's --api-key (leave blank if none)
INTERVAL=2                     # seconds between frame uploads
QUALITY=75                     # JPEG quality (lower = smaller uploads)

# --- radio front-end ---
# RTL-SDR reliably streams ~2.4 Msps; that bounds the reconstructable pixel
# clock, so RTL-SDR suits lower-resolution / lower-refresh targets. Wider
# front-ends (HackRF, USRP via SoapySDR) allow higher resolutions.
DRIVER=rtlsdr                  # SoapySDR driver, or "rtlsdr-native" for pyrtlsdr
SAMPLERATE=2400000
FREQUENCY=400000000            # tune near the target's pixel-clock harmonics
GAIN=auto

# --- video mode ---
# Leave HEIGHT/REFRESH blank to auto-detect blindly on the probe; the server can
# also push a mode at runtime. Set them to pin a known target.
HEIGHT=
REFRESH=

# --- testing without hardware ---
# Set SYNTHETIC=1 to run the built-in simulated source (no SDR needed).
SYNTHETIC=0
